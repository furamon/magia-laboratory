---
import BaseLayout from '@/layouts/BaseLayout'
---

<BaseLayout title='Text'>
	<div class='flex flex-col container mx-auto'>
		<h1 class='text-4xl font-bold text-center'>更新履歴</h1>
	</div>

	<table class='border-2 border-gray-700 mx-auto bg-gray-150'>
		<tr>
			<th class='border border-gray-500'>日付</th>
			<th class='border border-gray-500'>内容</th>
		</tr>
		<tr>
			<td class='border border-gray-500'>2024/06/02</td>
			<td class='border border-gray-500'>更新履歴整備</td>
		</tr>
		<tr>
			<td class='border border-gray-500'>2024/04/20</td>
			<td class='border border-gray-500'>雑記置き追加</td>
		</tr>
		<tr>
			<td class='border border-gray-500'>2024/02/06</td>
			<td class='border border-gray-500'><strong>リニューアルオープン</strong>。別館と統合</td>
		</tr>
	</table>
</BaseLayout>

<style>
	.btn-game {
		@apply bg-gray-600 hover:bg-gray-400 text-white rounded-full text-2xl text-center py-2 m-3;
	}
</style>

<script>
	import { animate } from 'motion'
	const showAnimations = localStorage.getItem('animations') === 'true'

	if (showAnimations) {
		animate(
			'.title',
			{ y: [80, 0], opacity: [0, 1] },
			{
				duration: 2.5,
				opacity: { duration: 3 },

				offset: [0, 0.55, 0.75]
			}
		)
	}
</script>
