{
	"name": "magia-laboratory",
	"type": "module",
	"version": "1.1.0",
	"description": "My astro blog",
	"author": "Furamon",
	"license": "GPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://magialaboratory.com"
	},
	"keywords": [
		"astro",
		"astrojs",
		"astro-template",
		"astro-blog",
		"astro-b"
	],
	"bugs": {
		"url": "https://github.com/furamon/magia-laboratory/issues"
	},
	"scripts": {
		"dev": "npx tinacms dev -c \"astro dev\"",
		"start": "astro dev",
		"build": "npx tinacms build -c \"astro build\"",
		"sync": "astro sync",
		"preview": "astro preview",
		"postbuild": "pagefind --site dist",
		"format:check": "prettier --plugin-search-dir=. --check .",
		"format": "prettier --plugin-search-dir=. --write .",
		"lint": "eslint .",
		"pre-commit": "lint-staged",
		"prepare": "husky install"
	},
	"dependencies": {
		"@astrojs/rss": "4.0.5",
		"astro": "4.7.1",
		"astro-font": "^0.0.80",
		"sharp": "^0.33.3"
	},
	"devDependencies": {
		"@astrojs/mdx": "2.3.1",
		"@astrojs/sitemap": "3.1.4",
		"@astrojs/tailwind": "5.1.0",
		"@pagefind/default-ui": "^1.1.0",
		"@tailwindcss/typography": "0.5.12",
		"@tinacms/cli": "^1.5.44",
		"@typescript-eslint/parser": "^7.7.1",
		"clsx": "2.1.1",
		"eslint": "^9.1.1",
		"eslint-plugin-astro": "^0.34.0",
		"eslint-plugin-jsx-a11y": "^6.8.0",
		"husky": "^9.0.11",
		"lint-staged": "^15.2.2",
		"mdast-util-to-string": "^4.0.0",
		"motion": "^10.17.0",
		"pagefind": "^1.1.0",
		"prettier": "^3.2.5",
		"prettier-config-standard": "^7.0.0",
		"prettier-plugin-astro": "^0.13.0",
		"reading-time": "^1.5.0",
		"slugify": "^1.6.6",
		"tailwind-merge": "2.3.0",
		"tailwindcss": "3.4.3",
		"tinacms": "^1.6.2",
		"typescript": "^5.4.5"
	},
	"lint-staged": {
		"*.{astro,js,jsx,ts,tsx,md,mdx,json}": [
			"prettier --write --plugin-search-dir=."
		]
	},
	"pnpm": {
		"overrides": {
			"sharp": "^0.33.0",
			"better-sqlite3": "^9.4.5"
		}
	},
	"packageManager": "pnpm@9.0.4+sha512.c374b52de3de88c58fd8333df664a737279cdb0e1344ba4054d3b1fffa9a1a3670854f755dca4f16adea3f14be9896a7fcaf167409fe0c1ad60475271dafe81a"
}
