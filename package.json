{
	"name": "magia-laboratory",
	"type": "module",
	"version": "1.1.0",
	"description": "My astro blog",
	"author": "Furamon",
	"license": "GPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://magialaboratory.com"
	},
	"keywords": [
		"astro",
		"astrojs",
		"astro-template",
		"astro-blog",
		"astro-b"
	],
	"bugs": {
		"url": "https://github.com/furamon/magia-laboratory/issues"
	},
	"scripts": {
		"dev": "npx tinacms dev -c \"astro dev\"",
		"start": "astro dev",
		"build": "npx tinacms build -c \"astro build\"",
		"sync": "astro sync",
		"preview": "astro preview",
		"postbuild": "pagefind --site dist",
		"format:check": "prettier --plugin-search-dir=. --check .",
		"format": "prettier --plugin-search-dir=. --write .",
		"lint": "eslint .",
		"pre-commit": "lint-staged",
		"prepare": "husky install"
	},
	"dependencies": {
		"@astro-community/astro-embed-youtube": "^0.5.6",
		"@astrojs/rss": "4.0.9",
		"astro": "4.16.16",
		"astro-font": "^0.1.81",
		"pnpm": "^9.14.4",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.1",
		"sharp": "^0.33.5",
		"unified": "^11.0.5"
	},
	"devDependencies": {
		"@astrojs/mdx": "3.1.9",
		"@astrojs/sitemap": "3.2.1",
		"@astrojs/tailwind": "5.1.2",
		"@pagefind/default-ui": "^1.2.0",
		"@tailwindcss/typography": "0.5.15",
		"@tinacms/cli": "^1.6.12",
		"@typescript-eslint/parser": "^8.16.0",
		"clsx": "2.1.1",
		"eslint": "^9.15.0",
		"eslint-plugin-astro": "^1.3.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"husky": "^9.1.7",
		"lint-staged": "^15.2.10",
		"mdast-util-to-string": "^4.0.0",
		"motion": "^11.12.0",
		"pagefind": "^1.2.0",
		"prettier": "^3.4.1",
		"prettier-config-standard": "^7.0.0",
		"prettier-plugin-astro": "^0.14.1",
		"reading-time": "^1.5.0",
		"slugify": "^1.6.6",
		"tailwind-merge": "2.5.5",
		"tailwindcss": "3.4.15",
		"tinacms": "^2.5.0",
		"typescript": "^5.7.2"
	},
	"lint-staged": {
		"*.{astro,js,jsx,ts,tsx,md,mdx,json}": [
			"prettier --write --plugin-search-dir=."
		]
	},
	"pnpm": {
		"overrides": {
			"sharp": "^0.33.0",
			"better-sqlite3": "^9.4.5"
		}
	},
	"packageManager": "pnpm@9.12.1"
}
