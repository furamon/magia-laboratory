{
	"name": "magia-laboratory",
	"type": "module",
	"version": "1.0.0",
	"description": "My astro blog",
	"author": "Furamon",
	"license": "GPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://magialaboratory.com"
	},
	"keywords": [
		"astro",
		"astrojs",
		"astro-template",
		"astro-blog",
		"astro-b"
	],
	"bugs": {
		"url": "https://github.com/furamon/magia-laboratory/issues"
	},
	"scripts": {
		"dev": "npx tinacms dev -c \"astro dev\"",
		"start": "astro dev",
		"build": "npx tinacms build -c \"astro build\"",
		"sync": "astro sync",
		"preview": "astro preview",
		"postbuild": "pagefind --site /var/www/html",
		"format:check": "prettier --plugin-search-dir=. --check .",
		"format": "prettier --plugin-search-dir=. --write .",
		"lint": "eslint .",
		"pre-commit": "lint-staged",
		"prepare": "husky install",
		"watch": "npm-watch"
	},
	"watch": {
		"build": {
			"patterns": [
				"src/content"
			],
			"extensions": "mdx,astro"
		}
	},
	"dependencies": {
		"@astro-community/astro-embed-youtube": "^0.5.6",
		"@astrojs/react": "^4.2.5",
		"@astrojs/rss": "4.0.11",
		"@philnash/astro-pagination": "^0.5.0",
		"@react-three/drei": "^10.0.6",
		"@react-three/fiber": "^9.1.2",
		"@tailwindcss/postcss": "^4.1.4",
		"@tailwindcss/vite": "^4.1.4",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"astro": "5.7.5",
		"astro-font": "^1.1.0",
		"fiber": "link:@types/react-three/fiber",
		"npm-watch": "^0.13.0",
		"pnpm": "^10.9.0",
		"postcss": "^8.5.3",
		"react": "^19.1.0",
		"react-device-detect": "^2.2.3",
		"react-dom": "^19.1.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"sharp": "^0.34.1",
		"three": "0.175.0",
		"tinacms": "^2.7.5",
		"unified": "^11.0.5"
	},
	"devDependencies": {
		"@astrojs/mdx": "4.2.5",
		"@astrojs/sitemap": "3.3.1",
		"@astrojs/tailwind": "6.0.2",
		"@pagefind/default-ui": "^1.3.0",
		"@tailwindcss/typography": "0.5.16",
		"@tinacms/cli": "^1.9.5",
		"@types/node": "^22.14.1",
		"@types/three": "^0.175.0",
		"@typescript-eslint/parser": "^8.31.0",
		"clsx": "2.1.1",
		"eslint": "^9.25.1",
		"eslint-plugin-astro": "^1.3.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.1",
		"mdast-util-to-string": "^4.0.0",
		"motion": "^12.8.0",
		"pagefind": "^1.3.0",
		"prettier": "^3.5.3",
		"prettier-config-standard": "^7.0.0",
		"prettier-plugin-astro": "^0.14.1",
		"reading-time": "^1.5.0",
		"slugify": "^1.6.6",
		"tailwind-merge": "3.2.0",
		"tailwindcss": "4.1.4",
		"typescript": "^5.8.3"
	},
	"lint-staged": {
		"*.{astro,js,jsx,ts,tsx,md,mdx,json}": [
			"prettier --write --plugin-search-dir=."
		]
	},
	"pnpm": {
		"overrides": {
			"sharp": "^0.33.0",
			"better-sqlite3": "^9.4.5"
		},
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild",
			"sharp"
		]
	},
	"packageManager": "pnpm@10.6.5"
}
